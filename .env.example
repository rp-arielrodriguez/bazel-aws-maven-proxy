# AWS Configuration
AWS_PROFILE=default
AWS_REGION=sa-east-1

# S3 Bucket Information
S3_BUCKET_NAME=your-maven-bucket

# Proxy Configuration
PROXY_PORT=8888
REFRESH_INTERVAL=60000  # Credential refresh check interval (ms)
LOG_LEVEL=info  # Options: debug, info, warn, error

# Pull-through mirror (optional)
# On an S3 miss, fetch the artifact from this upstream Maven repo and write it
# back to the bucket, turning the bucket into a self-filling mirror (upstream is
# hit at most once per artifact). Default is Google's Maven Central mirror, which
# (unlike repo1.maven.org) does not rate-limit per IP. Set empty to disable.
# UPSTREAM_MAVEN_URL=https://maven-central.storage-download.googleapis.com/maven2
# UPSTREAM_WRITE_BACK=true   # Write fetched artifacts back to S3 (needs s3:PutObject)
# UPSTREAM_WRITE_BUCKET=     # Bucket for write-back (default: S3_BUCKET_NAME). Set to a
#                            # bucket you own when the read bucket is read-only (e.g. a
#                            # cross-account mirror you can read but not write).
# UPSTREAM_PREFIX_STRIP=m2/  # Key prefix stripped before appending to upstream URL
# UPSTREAM_TIMEOUT=60        # Per-fetch timeout (seconds)

# SSO Monitor Configuration
CHECK_INTERVAL=60  # Credential check interval in seconds

# SSO Watcher Configuration (macOS launchd)
SSO_COOLDOWN_SECONDS=600  # Cooldown between login attempts (seconds)
SSO_POLL_SECONDS=5  # How often to check for signal file (seconds)
SSO_LOGIN_MODE=notify  # "notify" (dialog), "auto" (webview), "silent" (token refresh only), "standalone" (manual)
# Runtime toggle: mise run sso-mode:notify|auto|silent|standalone (overrides this)
SSO_PROACTIVE_REFRESH_MINUTES=30  # Refresh token N min before expiry (0 to disable)
# SSO_LOGIN_TIMEOUT=120  # SSO login timeout in seconds (default: 120)

# Container Engine
# Auto-detects podman (preferred) or docker. Override if needed.
# CONTAINER_ENGINE=podman  # Options: podman, docker (auto-detect if unset)

# Corporate Proxy / TLS
# Set to true if behind a proxy that intercepts HTTPS and replaces certificates.
# Enables --tls-verify=false for podman. For Docker, configure daemon-level CA trust.
# SKIP_TLS_VERIFY=false

# Corporate Proxy / SSL Inspection
# Path to CA certificate bundle for SSL inspection bypass.
# Required when behind corporate proxies that intercept HTTPS traffic.
# Run `bazel-proxy detect-proxy` to auto-configure.
# AWS_CA_BUNDLE=~/.aws/combined-ca-bundle.pem
